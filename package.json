{
  "name": "equipose",
  "version": "1.32.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve --port=3000",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "vitest run --exclude 'tests_e2e/**'",
    "test:e2e:a11y": "playwright test tests_e2e/a11y.spec.ts",
    "precommit": "npm run lint && npm run build && npm run test:unit && npm run test:e2e:a11y",
    "lint": "ng lint",
    "serve:ssr:app": "node dist/app/server/server.mjs",
    "prestart": "node generate-version.js",
    "prebuild": "node generate-version.js",
    "pretest": "node generate-version.js",
    "deploy": "pnpm run build && wrangler deploy",
    "preview": "pnpm run build && wrangler dev"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "21.2.6",
    "@angular/common": "21.2.7",
    "@angular/compiler": "21.2.7",
    "@angular/core": "21.2.7",
    "@angular/forms": "21.2.7",
    "@angular/material": "21.2.6",
    "@angular/platform-browser": "21.2.7",
    "@angular/platform-server": "21.2.7",
    "@angular/router": "21.2.7",
    "@angular/service-worker": "21.2.7",
    "@angular/ssr": "21.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@ngrx/signals": "^21.1.0",
    "echarts": "^6.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "motion": "^12.23.24",
    "rxjs": "~7.8.0",
    "seedrandom": "^3.0.5",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.8",
    "@angular/cli": "21.2.8",
    "@angular/compiler-cli": "21.2.7",
    "@angular/platform-browser-dynamic": "21.2.7",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/seedrandom": "^3.0.8",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "21.4.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "jsdom": "^29.1.0",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.12",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.3",
